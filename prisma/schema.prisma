generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(STUDENT)
  bio           String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  certificates     Certificate[]
  tracks           Track[]        @relation("InstructorTracks")
  enrollments      Enrollment[]
  notifications    Notification[]
  payments         Payment[]
  progress         Progress[]
  qaQuestions      QAQuestion[]
  quizAttempts     QuizAttempt[]
  reviews          Review[]
  auditLogs        AuditLog[]     @relation("AdminAuditLogs")
  sentNotifications SentNotification[] @relation("InstructorSentNotifications")
}

model Track {
  id                 String        @id @default(uuid())
  title              String
  subtitle           String?
  description        String
  thumbnail          String?
  price              Float         @default(0)
  categoryId         String?
  category           Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  language           String?       @default("English")
  level              String?       @default("All Levels")
  learningObjectives String?
  requirements       String?
  targetAudience     String?
  tags               String?
  previewVideoUrl    String?
  status             TrackStatus   @default(DRAFT)
  instructorId       String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  certificates       Certificate[]
  instructor         User          @relation("InstructorTracks", fields: [instructorId], references: [id])
  enrollments        Enrollment[]
  phases             Phase[]
  payments           Payment[]
  reviews            Review[]
  sentNotifications  SentNotification[]
}

model Phase {
  id        String   @id @default(uuid())
  title     String
  order     Int
  trackId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  modules   Module[]
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model Module {
  id          String   @id @default(uuid())
  title       String
  order       Int
  isPublished Boolean  @default(false)
  phaseId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  phase       Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id          String       @id @default(uuid())
  title       String
  videoPath   String?
  duration    Int?
  order       Int
  isPublished Boolean      @default(false)
  moduleId    String
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    Progress[]
  qaQuestions QAQuestion[]
  quizzes     Quiz[]
  resources   Resource[]
  videoAsset  VideoAsset?
}

model VideoAsset {
  id              String      @id @default(uuid())
  lessonId        String      @unique
  originalPath    String?
  hlsManifestPath String?
  duration        Int?
  status          VideoStatus @default(PROCESSING)
  errorMessage    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  lesson          Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  trackId    String
  status     EnrollmentStatus @default(PENDING)
  enrolledAt DateTime @default(now())
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
  id             String   @id @default(uuid())
  userId         String
  lessonId       String
  watchedPercent Float    @default(0)
  lastPosition   Int      @default(0)
  isCompleted    Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Quiz {
  id           String   @id @default(uuid())
  title        String
  passingScore Int      @default(50)
  maxAttempts  Int?
  lessonId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts  QuizAttempt[]
  questions QuizQuestion[]
}

model QuizAttempt {
  id        String   @id @default(uuid())
  userId    String
  quizId    String
  score     Int
  passed    Boolean
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

model QuizQuestion {
  id               String       @id @default(uuid())
  quizId           String
  questionText     String
  type             QuestionType
  order            Int
  correctTrueFalse Boolean?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]
}

model QuizOption {
  id         String   @id @default(uuid())
  questionId String
  optionText String
  isCorrect  Boolean  @default(false)
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Certificate {
  id         String   @id @default(uuid())
  userId     String
  trackId    String
  uniqueCode String   @unique
  issuedAt   DateTime @default(now())
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String        @id @default(uuid())
  userId    String
  trackId   String?
  amount    Float
  type      PaymentType
  status    PaymentStatus @default(PENDING)
  stripeId  String?       @unique
  couponId  String?
  createdAt DateTime      @default(now())
  coupon    Coupon?       @relation(fields: [couponId], references: [id])
  track     Track?        @relation(fields: [trackId], references: [id], onDelete: SetNull)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coupon {
  id           String       @id @default(uuid())
  code         String       @unique
  discountType DiscountType
  value        Float
  expiryDate   DateTime?
  createdAt    DateTime     @default(now())
  payments     Payment[]
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QAQuestion {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  question  String
  answer    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum TrackStatus {
  DRAFT
  PUBLISHED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
}

enum PaymentType {
  COURSE_PURCHASE
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  url       String
  lessonId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tracks    Track[]
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String?  
  action    String
  category  String   // USER_MGMT, CONTENT, SYSTEM, PAYMENT, FINANCE
  severity  String   // info, warning, success, error
  timestamp DateTime @default(now())
  ip        String?
  admin     User?    @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: SetNull)
}

model SentNotification {
  id           String   @id @default(uuid())
  senderId     String
  message      String
  type         String
  targetRole   String
  trackId      String?
  audienceSize Int      @default(0)
  createdAt    DateTime @default(now())
  sender       User     @relation("InstructorSentNotifications", fields: [senderId], references: [id], onDelete: Cascade)
  track        Track?   @relation(fields: [trackId], references: [id], onDelete: SetNull)
}
